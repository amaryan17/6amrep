# ═══════════════════# APPLICATION SETTINGS
# Enable/disable in-memory migration caching (true/false)
CACHE_ENABLED=true

# Maximum retry attempts for Bedrock invocations
MAX_RETRIES=3

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ════════════════════════════════════════════════════════════════════════════
# NOTION API CONFIGURATION (AGENT 5 - OPTIONAL)
# ════════════════════════════════════════════════════════════════════════════
# The Notion integration is OPTIONAL. If these keys are not set:
# - Migration analysis still works perfectly
# - Agent 5 (ADR publishing) is automatically disabled
# - No Architecture Decision Records are published to Notion
# - The system remains fully operational and non-blocking

# Notion Internal Integration Token (Bearer token for API authentication)
# Get from: https://www.notion.so/my-integrations
# Steps:
#   1. Go to https://www.notion.so/my-integrations
#   2. Click "Create new integration" or select existing
#   3. Copy the "Internal Integration Token" (starts with "secret_")
#   4. Paste it here
NOTION_API_KEY=secret_your_notion_api_key_here

# Notion Page ID (where ADRs will be published)
# Get from Notion page URL:
#   1. Open the page where you want ADRs to be stored
#   2. Copy the URL: https://www.notion.so/12a3b4c5d6e7f8g9h0i1j2k3l4m5n6o7?v=xyz
#   3. Extract the ID (the long hex string before ?v=): 12a3b4c5d6e7f8g9h0i1j2k3l4m5n6o7
#   4. Paste it here
# IMPORTANT: Share the Notion page with your integration (Grant "Edit" access)
NOTION_PAGE_ID=your_notion_page_id_here

# ════════════════════════════════════════════════════════════════════════════
# SECURITY NOTES
# ════════════════════════════════════════════════════════════════════════════
# 1. AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY should have minimal permissions
# 2. Consider using AWS IAM role with Bedrock-specific permissions instead
# 3. NOTION_API_KEY is sensitive - never share or commit to version control
# 4. Never commit .env to version control
# 5. Rotate credentials regularly
# 6. Use different credentials for dev/staging/prod environments
# ═════════════════════════════════════════════════════════════════════════════════════════════════════════════════
# AEGIS MIGRATION FACTORY - ENVIRONMENT CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual AWS credentials
# DO NOT commit .env file to version control!
# ════════════════════════════════════════════════════════════════════════════

# AWS CREDENTIALS
# Your AWS Access Key ID
AWS_ACCESS_KEY_ID=your_access_key_id_here

# Your AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# AWS Region (default: us-east-1)
AWS_DEFAULT_REGION=us-east-1

# BEDROCK CONFIGURATION
# Model ID for Claude 3.5 Sonnet (latest version)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# APPLICATION SETTINGS
# Enable/disable in-memory migration caching (true/false)
CACHE_ENABLED=true

# Maximum retry attempts for Bedrock invocations
MAX_RETRIES=3

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ════════════════════════════════════════════════════════════════════════════
# SECURITY NOTES
# ════════════════════════════════════════════════════════════════════════════
# 1. AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY should have minimal permissions
# 2. Consider using AWS IAM role with Bedrock-specific permissions instead
# 3. Never commit .env to version control
# 4. Rotate credentials regularly
# 5. Use different credentials for dev/staging/prod environments
# ════════════════════════════════════════════════════════════════════════════
